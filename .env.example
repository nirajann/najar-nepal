# Shared defaults can live in `.env`
PORT=5000
VITE_API_BASE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5173
REQUEST_TIMEOUT_MS=30000
JSON_BODY_LIMIT=1mb

# Development-only secrets can live in `.env.development`
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/najar-nepal-local
JWT_SECRET=replace_with_local_dev_secret

# Production values should live in real platform env vars or `.env.production`
# NODE_ENV=production
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# JWT_SECRET=replace_with_long_random_secret
# VITE_API_BASE_URL=https://your-api.example.com/api
# CORS_ORIGINS=https://your-frontend.example.com,https://staging-your-frontend.example.com
